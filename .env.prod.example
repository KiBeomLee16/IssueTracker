# Copy this file to .env on the production server and replace every change-this value.
# Do not commit the real .env file.

APP_PORT=8080

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=issue_tracker
MYSQL_USER=issue_user
MYSQL_PASSWORD=change-this-db-password

JWT_SECRET=change-this-to-a-random-secret-at-least-64-characters
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=1209600000
JWT_REFRESH_CLEANUP_INTERVAL_MS=3600000

DDL_AUTO=validate

# Enable this only once when creating the first cloud admin account.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_USER_ID=admin01
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-this-admin-password
